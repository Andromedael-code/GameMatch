rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function roomPath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function memberPath(roomId, userId) {
      return /databases/$(database)/documents/rooms/$(roomId)/members/$(userId);
    }

    function isRoomMember(roomId) {
      return signedIn() && exists(memberPath(roomId, request.auth.uid));
    }

    function isRoomHost(roomId) {
      return signedIn() && exists(roomPath(roomId)) && get(roomPath(roomId)).data.createdBy == request.auth.uid;
    }

    function touchesOwnMembership(roomId) {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberCount", "memberIds"])
        && request.resource.data.memberIds is list
        && resource.data.memberIds is list
        && (
          request.resource.data.memberIds.hasAny([request.auth.uid])
          || resource.data.memberIds.hasAny([request.auth.uid])
        );
    }

    function includesRequester(listValue) {
      return listValue is list && listValue.hasAny([request.auth.uid]);
    }

    match /users/{userId} {
      allow read, create, update, delete: if isSelf(userId);

      match /likedGames/{gameId} {
        allow read, create, update, delete: if isSelf(userId);
      }

      match /matchHistory/{matchId} {
        allow read, delete: if isSelf(userId);
        allow create, update: if isSelf(userId)
          || (
            signedIn()
            && request.resource.data.likedBy is list
            && request.resource.data.likedBy.hasAny([userId])
            && includesRequester(request.resource.data.likedBy)
          );
      }
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.hasOnly([request.auth.uid]);
      allow update: if isRoomHost(roomId) || touchesOwnMembership(roomId);
      allow delete: if isRoomHost(roomId)
        || (
          signedIn()
          && resource.data.memberIds is list
          && resource.data.memberIds.size() == 1
          && resource.data.memberIds[0] == request.auth.uid
        );

      match /members/{memberId} {
        allow read: if isRoomMember(roomId) || isSelf(memberId);
        allow create, update: if isSelf(memberId) || isRoomHost(roomId);
        allow delete: if isSelf(memberId) || isRoomHost(roomId);
      }

      match /votes/{gameId} {
        allow read: if isRoomMember(roomId);
        allow create, update: if isRoomMember(roomId) && includesRequester(request.resource.data.memberIds);
        allow delete: if isRoomHost(roomId);
      }

      match /matches/{gameId} {
        allow read: if isRoomMember(roomId);
        allow create, update: if isRoomMember(roomId) && includesRequester(request.resource.data.likedBy);
        allow delete: if isRoomHost(roomId);
      }
    }
  }
}
